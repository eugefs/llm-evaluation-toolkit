{
  "$defs": {
    "BenchmarkCase": {
      "additionalProperties": false,
      "description": "Single benchmark metadata.",
      "properties": {
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "category": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Category"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        }
      },
      "required": [
        "id"
      ],
      "title": "BenchmarkCase",
      "type": "object"
    },
    "BenchmarkMetadata": {
      "additionalProperties": false,
      "description": "Additional benchmark information.",
      "properties": {
        "author": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Author"
        },
        "created": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Created"
        },
        "license": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "License"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        }
      },
      "title": "BenchmarkMetadata",
      "type": "object"
    },
    "BenchmarkMetric": {
      "additionalProperties": false,
      "description": "Metric configuration.",
      "properties": {
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "BenchmarkMetric",
      "type": "object"
    },
    "BenchmarkProfile": {
      "additionalProperties": false,
      "description": "Named benchmark execution profile.",
      "properties": {
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "providers": {
          "items": {
            "$ref": "#/$defs/ProviderConfig"
          },
          "title": "Providers",
          "type": "array"
        }
      },
      "required": [
        "name"
      ],
      "title": "BenchmarkProfile",
      "type": "object"
    },
    "BenchmarkProvider": {
      "additionalProperties": false,
      "description": "Provider configuration.",
      "properties": {
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model"
        }
      },
      "required": [
        "name"
      ],
      "title": "BenchmarkProvider",
      "type": "object"
    },
    "EvaluationCase": {
      "additionalProperties": false,
      "description": "A single evaluation example.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "request": {
          "$ref": "#/$defs/GenerationRequest"
        },
        "expected_output": {
          "title": "Expected Output",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Metadata",
          "type": "object"
        }
      },
      "required": [
        "id",
        "request",
        "expected_output"
      ],
      "title": "EvaluationCase",
      "type": "object"
    },
    "EvaluationDataset": {
      "additionalProperties": false,
      "description": "A collection of evaluation cases.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "cases": {
          "items": {
            "$ref": "#/$defs/EvaluationCase"
          },
          "title": "Cases",
          "type": "array"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        }
      },
      "required": [
        "name"
      ],
      "title": "EvaluationDataset",
      "type": "object"
    },
    "GenerationMessage": {
      "additionalProperties": false,
      "description": "A single message in a generation request.",
      "properties": {
        "role": {
          "enum": [
            "system",
            "user",
            "assistant",
            "tool"
          ],
          "title": "Role",
          "type": "string"
        },
        "content": {
          "title": "Content",
          "type": "string"
        }
      },
      "required": [
        "role",
        "content"
      ],
      "title": "GenerationMessage",
      "type": "object"
    },
    "GenerationRequest": {
      "additionalProperties": false,
      "description": "A provider-independent generation request.",
      "properties": {
        "messages": {
          "items": {
            "$ref": "#/$defs/GenerationMessage"
          },
          "title": "Messages",
          "type": "array"
        },
        "temperature": {
          "default": 0.0,
          "maximum": 2.0,
          "minimum": 0.0,
          "title": "Temperature",
          "type": "number"
        },
        "max_tokens": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Tokens"
        }
      },
      "required": [
        "messages"
      ],
      "title": "GenerationRequest",
      "type": "object"
    },
    "ProviderConfig": {
      "additionalProperties": false,
      "description": "Provider execution configuration.",
      "properties": {
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model"
        },
        "temperature": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Temperature"
        }
      },
      "required": [
        "name"
      ],
      "title": "ProviderConfig",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Benchmark definition.",
  "properties": {
    "name": {
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "version": {
      "minLength": 1,
      "title": "Version",
      "type": "string"
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Description"
    },
    "metadata": {
      "anyOf": [
        {
          "$ref": "#/$defs/BenchmarkMetadata"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "dataset": {
      "$ref": "#/$defs/EvaluationDataset"
    },
    "providers": {
      "items": {
        "$ref": "#/$defs/BenchmarkProvider"
      },
      "title": "Providers",
      "type": "array"
    },
    "metrics": {
      "items": {
        "$ref": "#/$defs/BenchmarkMetric"
      },
      "title": "Metrics",
      "type": "array"
    },
    "profiles": {
      "items": {
        "$ref": "#/$defs/BenchmarkProfile"
      },
      "title": "Profiles",
      "type": "array"
    },
    "cases": {
      "items": {
        "$ref": "#/$defs/BenchmarkCase"
      },
      "title": "Cases",
      "type": "array"
    }
  },
  "required": [
    "name",
    "version",
    "dataset"
  ],
  "title": "Benchmark",
  "type": "object"
}